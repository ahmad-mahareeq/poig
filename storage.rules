rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Anyone can read photos (public site)
    match /photos/{allPaths=**} {
      allow read: if true;
    }

    // Only authenticated admins can upload/delete
    match /photos/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
